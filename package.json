{
  "name": "jesscms",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create jesscms-db",
    "db:migrate:local": "wrangler d1 migrations apply jesscms-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply jesscms-db --remote",
    "types": "wrangler types",
    "user:create-admin": "node scripts/create-admin.mjs",
    "user:reset-password": "node scripts/reset-password.mjs",
    "user:list": "node scripts/reset-password.mjs --list",
    "test:admin": "node scripts/admin-smoke-test.mjs",
    "test:editor": "node scripts/block-editor-smoke-test.mjs",
    "test:frontend": "node scripts/frontend-smoke-test.mjs",
    "test:media": "node scripts/media-smoke-test.mjs",
    "test:forms": "node scripts/forms-smoke-test.mjs",
    "test:workflow": "node scripts/workflow-smoke-test.mjs",
    "test:extensibility": "node scripts/extensibility-smoke-test.mjs",
    "test:runtime": "node scripts/runtime-smoke-test.mjs",
    "plugins:validate": "node scripts/plugins-cli.mjs validate",
    "plugins:list": "node scripts/plugins-cli.mjs list",
    "plugins:sync": "node scripts/plugins-cli.mjs sync",
    "plugins:refresh": "node scripts/plugins-cli.mjs refresh"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250317.0",
    "typescript": "^5.8.3",
    "wrangler": "^4.14.0"
  }
}
