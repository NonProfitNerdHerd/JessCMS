  "navigation": {
    "sections": [
      { "id": "storm", "label": "Storm", "sort_order": 15 }
    ],
    "items": [
      { "section_id": "storm", "label": "Chases", "href": "/admin/chases", "icon": "🌪", "sort_order": 10, "permission": "storm.chase.read" },
      { "section_id": "storm", "label": "Warnings", "href": "/admin/warnings", "icon": "⚠", "sort_order": 20, "permission": "storm.warning.read" }
    ]
  },
  "settings_pages": [
    {
      "slug": "storm",
      "label": "Storm",
      "icon": "🌪",
      "permission": "settings:read"
    }
  ],
  "cleanup_policy": "retain",
  "database": {
    "migrations_dir": "plugins/storm-platform/migrations"
  }
