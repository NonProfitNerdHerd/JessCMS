{
  "id": "storm-platform",
  "name": "Storm Platform",
  "version": "0.1.0",
  "description": "Storm chaser vertical content types: chases, vehicles, cameras, warnings, and scanner feeds.",
  "author": "JessCMS",
  "homepage": "https://github.com/ike-j-rebout/JessCMS",
  "minimum_jesscms_version": "0.9.0",
  "enabled": false,
  "kind": "plugin",
  "dependencies": [
    { "plugin_id": "core-media" }
  ],
  "optional_dependencies": [
    { "plugin_id": "storm-chaser-example" }
  ],
  "permissions": [
    "storm.chase.read",
    "storm.chase.write",
    "storm.vehicle.read",
    "storm.camera.read",
    "storm.warning.read",
    "storm.scanner.read"
  ],
  "content_types": [
    {
      "type_key": "vehicle",
      "label": "Vehicle",
      "plural_label": "Vehicles",
      "description": "Chase vehicles and equipment",
      "source": "plugin",
      "enabled": true,
      "supports_json": true,
      "supports_html": false,
      "supports_revisions": false,
      "supports_workflow": false,
      "supports_seo": false,
      "supports_featured_image": true,
      "supports_public_routes": true,
      "route_base": "/vehicles",
      "admin_base": "/admin/vehicles",
      "icon": "🚐"
    },
    {
      "type_key": "camera",
      "label": "Camera",
      "plural_label": "Cameras",
      "description": "Live and recorded camera feeds",
      "source": "plugin",
      "enabled": true,
      "supports_json": true,
      "supports_html": false,
      "supports_revisions": false,
      "supports_workflow": false,
      "supports_seo": false,
      "supports_public_routes": true,
      "route_base": "/cameras",
      "admin_base": "/admin/cameras",
      "icon": "📹"
    },
    {
      "type_key": "warning",
      "label": "Warning",
      "plural_label": "Warnings",
      "description": "Weather alerts and warnings",
      "source": "plugin",
      "enabled": true,
      "supports_json": true,
      "supports_html": true,
      "supports_revisions": true,
      "supports_workflow": true,
      "supports_seo": false,
      "supports_public_routes": true,
      "route_base": "/warnings",
      "admin_base": "/admin/warnings",
      "icon": "⚠"
    },
    {
      "type_key": "scanner_feed",
      "label": "Scanner Feed",
      "plural_label": "Scanner Feeds",
      "description": "Public safety scanner audio streams",
      "source": "plugin",
      "enabled": true,
      "supports_json": true,
      "supports_html": false,
      "supports_revisions": false,
      "supports_workflow": false,
      "supports_seo": false,
      "supports_public_routes": true,
      "route_base": "/scanner",
      "admin_base": "/admin/scanner-feeds",
      "icon": "📻"
    }
  ],
  "settings_pages": [
    {
      "slug": "storm",
      "label": "Storm",
      "icon": "🌪",
      "permission": "settings:read"
    }
  ],
  "cleanup_policy": "retain",
  "database": {
    "migrations_dir": "plugins/storm-platform/migrations"
  }
}
