{
  "id": "forms-builder",
  "name": "Forms Builder",
  "version": "0.1.0",
  "description": "Build contact forms, surveys, and lead capture forms with submissions inbox.",
  "author": "JessCMS",
  "homepage": "https://github.com/ike-j-rebout/JessCMS",
  "minimum_jesscms_version": "0.9.0",
  "enabled": true,
  "kind": "required",
  "permissions": [
    "forms:read",
    "forms:create",
    "forms:update",
    "forms:delete",
    "forms:publish",
    "forms:export",
    "forms:notifications",
    "forms:submissions:read",
    "forms:submissions:update"
  ],
  "content_types": [
    {
      "type_key": "form",
      "label": "Form",
      "plural_label": "Forms",
      "description": "Forms builder entries (admin-managed, embeddable)",
      "source": "plugin",
      "enabled": true,
      "supports_json": false,
      "supports_html": false,
      "supports_revisions": false,
      "supports_workflow": false,
      "supports_seo": false,
      "supports_featured_image": false,
      "supports_author": true,
      "supports_public_routes": false,
      "admin_base": "/admin/forms",
      "icon": "📋"
    }
  ],
  "api_routes": [
    { "method": "GET", "path": "/forms", "handler": "listForms" },
    { "method": "POST", "path": "/forms", "handler": "createForm" },
    { "method": "GET", "path": "/forms/:id", "handler": "getForm" },
    { "method": "PUT", "path": "/forms/:id", "handler": "updateForm" },
    { "method": "DELETE", "path": "/forms/:id", "handler": "deleteForm" },
    { "method": "GET", "path": "/public/forms/:slug", "handler": "getPublicForm" },
    { "method": "POST", "path": "/public/forms/:slug/submit", "handler": "submitPublicForm" }
  ],
  "blocks": [
    {
      "type": "form",
      "label": "Form",
      "category": "forms"
    }
  ],
  "resources": [
    { "resource_type": "table", "resource_name": "forms", "table_name": "forms", "ownership_type": "owns", "cleanup_policy": "retain" },
    { "resource_type": "table", "resource_name": "form_fields", "table_name": "form_fields", "ownership_type": "owns", "cleanup_policy": "delete" },
    { "resource_type": "table", "resource_name": "form_submissions", "table_name": "form_submissions", "ownership_type": "owns", "cleanup_policy": "archive" }
  ],
  "settings_pages": [
    {
      "slug": "forms",
      "label": "Forms",
      "icon": "📋",
      "permission": "forms:read"
    }
  ],
  "cleanup_policy": "retain",
  "database": {
    "tables": ["forms", "form_fields", "form_submissions"]
  }
}
